# soc-supply — third-party / supply-chain exposure monitor

SUPPLY_PORT=8109
SUPPLY_HOST=127.0.0.1
SUPPLY_DB=./supply.db

# PRIVACY. 0 = only your self-hosted soc-intel is queried; the party register
# never leaves this host. 1 = additionally send each party domain to Hudson Rock
# (via soc-intel /enrich) for a live infostealer lookup. The register itself is
# never uploaded in either mode.
EXTERNAL_LOOKUPS=0

# Background rescan of the whole register, in hours. 0 disables.
SCAN_INTERVAL_H=24

# soc-intel (read-only: this service never writes to it)
SOCINT_API_URL=http://localhost:8000/api
SOCINT_USER=admin@socint.internal
SOCINT_PASS=changeme123!

HTTP_TIMEOUT=10
